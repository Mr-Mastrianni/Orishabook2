rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Fields:
    //   - authorId: string (required)
    //   - authorName: string (required)
    //   - content: string (required, max 5000 chars)
    //   - timestamp: number (required)
    //   - tags: list (optional)
    //   - threadId: string (optional)
    //
    // Collection: notes
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - category: string
    //   - tags: list
    //
    // Document: config/council
    // Fields:
    //   - mode: string (quiet, debate, roundup)
    //   - activeMembers: list of strings
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'content', 'timestamp']) &&
             data.authorId is string &&
             data.authorName is string &&
             data.content is string && data.content.size() < 5000 &&
             data.timestamp is number;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'content']) &&
             data.title is string &&
             data.content is string;
    }

    function isValidConfig(data) {
      return data.keys().hasAll(['mode', 'model', 'activeMembers']) &&
             data.mode in ['quiet', 'debate', 'roundup'] &&
             data.model is string &&
             data.activeMembers is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && isValidPost(request.resource.data);
      allow delete: if isAuthenticated(); // For prototype cleanup
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidNote(request.resource.data);
    }

    match /config/council {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidConfig(request.resource.data);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
